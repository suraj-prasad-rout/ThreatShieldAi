{
  "manifest_version": 3,
  "name": "ThreatShield AI",
  "version": "2.0.0",
  "description": "Real-time web protection by ThreatShield AI — blocks malicious URLs, phishing sites, and dangerous downloads.",
  "permissions": [
    "webNavigation",
    "downloads",
    "tabs",
    "storage",
    "notifications",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:8766/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
